{
  "buffer_line_height": "comfortable",
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "buffer_font_family": "JetBrains Mono",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "vim_mode": true,
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night Light",
    "dark": "Tokyo Night"
  },
  "colorize_brackets": false,
  "buffer_font_size": 13.0,
  "terminal": {
    "font_size": 13
  }
}
